---
import '../styles/global.css';
import { SITE_NAME, SITE_URL, canonical } from '../lib/seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette';
import { TOOLS } from '../data/tools';

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  jsonLd?: object[] | object;
  noindex?: boolean;
}

const { title, description, path, ogImage, jsonLd, noindex = false } = Astro.props;
const url = canonical(path);
const image = ogImage || `${SITE_URL}/og-default.png`;
const ldArr = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={SITE_NAME} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    {ldArr.map(ld => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)}></script>
    ))}

    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var dark = saved ? saved === 'dark' : prefersDark || saved === null;
          if (dark) document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-bg text-fg antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 w-full">
      <slot />
    </main>
    <Footer />
    <CommandPalette client:idle tools={TOOLS.map(t => ({ slug: t.slug, title: t.title, category: t.category, description: t.subtitle }))} />
  </body>
</html>
