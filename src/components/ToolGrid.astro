---
import { TOOLS, CATEGORIES, toolsByCategory } from '../data/tools';

const grouped = toolsByCategory();
---
<div class="space-y-10">
  {CATEGORIES.map(cat => (
    grouped[cat.id].length > 0 && (
      <section aria-labelledby={`cat-${cat.id}`}>
        <header class="mb-3 flex items-baseline justify-between">
          <h2 id={`cat-${cat.id}`} class="text-sm font-semibold uppercase tracking-wider text-muted">{cat.label}</h2>
          <span class="text-xs text-muted">{cat.blurb}</span>
        </header>
        <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {grouped[cat.id].map(t => {
            const primaryMarkdown = cat.id === 'Markdown' && t.slug === 'to-markdown';
            return (
            <li class={primaryMarkdown ? 'sm:col-span-2 lg:col-span-2' : ''}>
              <a
                href={`/${t.slug}`}
                class={`card block h-full transition-all hover:border-accent/60 hover:translate-y-[-1px] ${primaryMarkdown ? 'p-5 bg-elevated border-accent/45' : 'p-4'}`}
              >
                <div class={primaryMarkdown ? 'text-lg font-semibold tracking-tight' : 'font-medium tracking-tight'}>{t.title}</div>
                <div class={`${primaryMarkdown ? 'text-sm' : 'text-xs line-clamp-2'} text-muted mt-1`}>{t.subtitle}</div>
              </a>
            </li>
            );
          })}
        </ul>
      </section>
    )
  ))}
</div>
