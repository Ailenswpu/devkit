---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolGrid from '../components/ToolGrid.astro';
import { SITE_NAME, toolsCollectionLD } from '../lib/seo';
import { TOOLS } from '../data/tools';
import { SEO_VARIANTS } from '../data/seoVariants';
import { CONVERSION_PAGES } from '../data/conversions';
---
<BaseLayout
  title={`All tools — ${SITE_NAME}`}
  description={`Browse all ${TOOLS.length} developer tools on ${SITE_NAME}. JSON, Base64, regex, hashes and more — all client-side and free.`}
  path="/tools"
  jsonLd={toolsCollectionLD(TOOLS)}
>
  <section class="max-w-6xl mx-auto px-4 pt-10 pb-16">
    <h1 class="text-3xl font-semibold tracking-tight">All tools</h1>
    <p class="mt-2 text-muted">{TOOLS.length} tools, organized by category. Hit <span class="kbd">⌘K</span> from any page to search.</p>
    <div class="mt-8"><ToolGrid /></div>
  </section>

  <section class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 py-12 prose-tool">
      <h2>Developer time tools for timestamps, cron and time zones</h2>
      <p>
        The Time category is designed for common search and debugging tasks: convert Unix timestamps, get the
        current epoch time, explain cron expressions, compare time zones, calculate date differences, add or subtract
        dates, create countdowns, validate ISO 8601 strings, generate Discord timestamp tags, convert durations,
        find ISO week numbers and calculate ages or anniversaries.
      </p>
      <p>
        These pages render crawlable definitions, examples, FAQs and related links in static HTML, while the
        interactive calculators run locally in the browser. Cron preset pages provide direct answers for schedules
        such as <a class="text-accent" href="/cron/every-5-minutes">every 5 minutes</a>, <a class="text-accent" href="/cron/every-weekday">every weekday</a> and <a class="text-accent" href="/cron/monthly-at-9am">monthly at 9 AM</a>.
      </p>
    </div>
  </section>

  <section class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="grid gap-8 md:grid-cols-2">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">No-upload and offline intent pages</h2>
          <p class="mt-3 text-muted leading-7">
            These focused pages explain privacy-oriented workflows for users searching for local, client-side,
            no-upload developer tools.
          </p>
          <ul class="mt-4 grid gap-2 text-sm">
            {SEO_VARIANTS.map((page) => (
              <li><a class="text-accent hover:underline" href={`/${page.slug}`}>{page.title}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">Conversion quick references</h2>
          <p class="mt-3 text-muted leading-7">
            Each reference page includes a concrete input, output, FAQ and link to the interactive browser-side tool.
          </p>
          <ul class="mt-4 columns-1 sm:columns-2 gap-8 text-sm">
            {CONVERSION_PAGES.map((page) => (
              <li class="break-inside-avoid"><a class="text-accent hover:underline" href={`/${page.slug}`}>{page.title}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
