---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CHANGELOG } from '../data/changelog';
---
<BaseLayout title="Changelog — DevKit" description="Recent updates and new tools on DevKit." path="/changelog">
  <article class="max-w-3xl mx-auto px-4 pt-10 pb-16 prose-tool">
    <header class="flex items-baseline justify-between flex-wrap gap-2">
      <h1 class="text-3xl font-semibold tracking-tight">Changelog</h1>
      <a href="/feed.xml" class="text-sm text-accent hover:underline" rel="alternate" type="application/rss+xml">
        Subscribe via RSS →
      </a>
    </header>

    <p class="text-muted mt-2">Follow new tools and improvements. The RSS feed is updated with every release.</p>

    <div class="mt-8 space-y-10">
      {CHANGELOG.map((e) => (
        <section id={e.version}>
          <header class="flex items-baseline gap-3 flex-wrap">
            <h2 class="!mt-0">{e.version}</h2>
            <span class="text-sm text-muted">{e.date}</span>
          </header>
          <p class="font-medium">{e.title}</p>
          <p class="text-muted">{e.summary}</p>
          <ul>
            {e.items.map((i) => <li>{i}</li>)}
          </ul>
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
