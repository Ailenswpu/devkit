---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS } from '../data/tools';
const popular = TOOLS.slice(0, 6);
---
<BaseLayout title="Not found — DevKit" description="That page doesn't exist. Browse all tools instead." path="/404" noindex>
  <section class="max-w-3xl mx-auto px-4 pt-16 pb-24 text-center">
    <div class="text-6xl font-semibold tracking-tight">404</div>
    <p class="mt-3 text-muted">That page doesn't exist. Here are some popular tools:</p>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2">
      {popular.map(t => (
        <li><a href={`/${t.slug}`} class="card p-4 block text-left hover:border-accent/60">
          <div class="font-medium">{t.title}</div>
          <div class="text-xs text-muted mt-1">{t.subtitle}</div>
        </a></li>
      ))}
    </ul>
    <a href="/" class="btn mt-6 inline-flex">Back home</a>
  </section>
</BaseLayout>
