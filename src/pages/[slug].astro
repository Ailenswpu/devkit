---
import ToolLayout from '../layouts/ToolLayout.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOLS, TOOLS_BY_SLUG } from '../data/tools';
import { SEO_VARIANTS, SEO_VARIANTS_BY_SLUG } from '../data/seoVariants';
import { CONVERSION_PAGES, CONVERSION_PAGES_BY_SLUG } from '../data/conversions';
import { SITE_NAME, canonical } from '../lib/seo';

export function getStaticPaths() {
  return [
    ...TOOLS.map(t => ({ params: { slug: t.slug }, props: { kind: 'tool', tool: t } })),
    ...SEO_VARIANTS.map(variant => ({ params: { slug: variant.slug }, props: { kind: 'variant', variant } })),
    ...CONVERSION_PAGES.map(conversion => ({ params: { slug: conversion.slug }, props: { kind: 'conversion', conversion } })),
  ];
}

const { kind, tool, variant, conversion } = Astro.props;

const page = variant || conversion;
const parentTool = page ? TOOLS_BY_SLUG.get(page.toolSlug) : null;
const availability = conversion?.availability || 'client';
const relatedPages = page?.related.map((slug: string) => {
  const relatedTool = TOOLS_BY_SLUG.get(slug);
  if (relatedTool) return { slug, title: relatedTool.title, description: relatedTool.subtitle };
  const relatedVariant = SEO_VARIANTS_BY_SLUG.get(slug);
  if (relatedVariant) return { slug, title: relatedVariant.title, description: relatedVariant.description };
  const relatedConversion = CONVERSION_PAGES_BY_SLUG.get(slug);
  if (relatedConversion) return { slug, title: relatedConversion.title, description: relatedConversion.description };
  return null;
}).filter(Boolean);

const pageJsonLd = page ? [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: page.h1,
    description: page.description,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    url: canonical(`/${page.slug}`),
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    isAccessibleForFree: true,
    inLanguage: 'en',
    publisher: { '@type': 'Organization', name: SITE_NAME, url: canonical('/') },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: canonical('/') },
      { '@type': 'ListItem', position: 2, name: parentTool?.title || 'Tools', item: parentTool ? canonical(`/${parentTool.slug}`) : canonical('/tools') },
      { '@type': 'ListItem', position: 3, name: page.title, item: canonical(`/${page.slug}`) },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: page.faq.map((item: { q: string; a: string }) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
] : [];
---
{kind === 'tool' && <ToolLayout tool={tool} />}

{kind !== 'tool' && page && (
  <BaseLayout
    title={`${page.title} | ${SITE_NAME}`}
    description={page.description}
    path={`/${page.slug}`}
    jsonLd={pageJsonLd}
  >
    <article class="max-w-4xl mx-auto px-4 pt-10 pb-16">
      <nav aria-label="Breadcrumb" class="text-xs text-muted mb-4">
        <a class="hover:text-fg" href="/">Home</a>
        <span aria-hidden="true"> / </span>
        {parentTool ? <a class="hover:text-fg" href={`/${parentTool.slug}`}>{parentTool.title}</a> : <a class="hover:text-fg" href="/tools">Tools</a>}
        <span aria-hidden="true"> / </span>
        <span class="text-fg">{page.title}</span>
      </nav>

      <header class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{page.h1}</h1>
        <p class="mt-4 text-lg text-muted leading-8">{page.intro}</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs">
          {availability === 'server' ? (
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-border text-muted">Server fetch required for live URLs</span>
          ) : availability === 'planned' ? (
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-border text-muted">Planned direct OCR support</span>
          ) : (
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-border text-muted">Runs in your browser</span>
          )}
          {availability !== 'server' && <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-border text-muted">No upload</span>}
          <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-border text-muted">Free · no signup</span>
        </div>
      </header>

      <section class="mt-6 border-l-2 border-accent pl-4 max-w-3xl">
        <h2 class="text-sm font-semibold uppercase text-muted">Direct answer</h2>
        <p class="mt-2 text-sm md:text-base leading-7 text-muted">
          <strong class="text-fg">{page.h1}</strong> is a browser-side workflow connected to
          {' '}<a class="text-accent" href={`/${parentTool?.slug || 'tools'}`}>{parentTool?.title || 'inbrowser.sh tools'}</a>.
          {conversion?.availability === 'server'
            ? <> Live URL fetching needs a server-side fetcher because of CORS and abuse controls; the linked tool converts saved HTML locally today.</>
            : conversion?.availability === 'planned'
              ? <> Direct image OCR is planned; the linked tool accepts extracted OCR text today.</>
              : conversion
            ? <> It converts <strong class="text-fg">{conversion.inputLabel}</strong> to <strong class="text-fg">{conversion.outputLabel}</strong> without requiring an upload.</>
            : <> It is designed for users who want a local, no-upload developer utility with static examples and FAQ content.</>}
        </p>
      </section>

      <section class="mt-8 grid gap-4 md:grid-cols-2">
        <div class="card p-4">
          <div class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">{page.inputLabel || 'Input'}</div>
          <pre class="overflow-auto text-sm font-mono whitespace-pre-wrap">{page.example.input}</pre>
        </div>
        <div class="card p-4">
          <div class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">{page.outputLabel || 'Output'}</div>
          <pre class="overflow-auto text-sm font-mono whitespace-pre-wrap">{page.example.output}</pre>
        </div>
        {page.example.note && <p class="md:col-span-2 text-sm text-muted">{page.example.note}</p>}
      </section>

      <div class="mt-10 grid gap-8 md:grid-cols-3">
        <div class="md:col-span-2 prose-tool">
          <h2>When to use it</h2>
          <ul>
            {page.useCases?.map((item: string) => <li>{item}</li>)}
            {page.steps?.map((item: string) => <li>{item}</li>)}
          </ul>

          <h2>Use the interactive tool</h2>
          <p>
            Open <a class="text-accent" href={`/${parentTool?.slug || 'tools'}`}>{parentTool?.title || 'All tools'}</a>
            {' '}to run the workflow locally in your browser. This page is static HTML for search, examples and quick reference.
          </p>

          <h2>FAQ</h2>
          <div class="space-y-2">
            {page.faq.map((item: { q: string; a: string }) => (
              <details class="card p-4">
                <summary class="cursor-pointer font-medium">{item.q}</summary>
                <p class="mt-2 text-sm text-muted">{item.a}</p>
              </details>
            ))}
          </div>
        </div>

        <aside class="space-y-4">
          <div class="card p-4">
            <div class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">Privacy</div>
            <p class="text-sm text-muted">
              {availability === 'server'
                ? 'Live URL fetching needs a server-side request. Saved HTML conversion in the linked tool remains browser-side.'
                : availability === 'planned'
                  ? 'Direct image OCR is planned. For now, paste text extracted by an OCR workflow you trust.'
                  : 'The linked tool runs client-side. Your input does not need to be uploaded for this workflow.'}
            </p>
          </div>
          {relatedPages && relatedPages.length > 0 && (
            <div class="card p-4">
              <div class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">Related pages</div>
              <ul class="space-y-2 text-sm">
                {relatedPages.map((item: any) => (
                  <li>
                    <a class="text-accent hover:underline" href={`/${item.slug}`}>{item.title}</a>
                    <div class="text-xs text-muted">{item.description}</div>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </article>
  </BaseLayout>
)}
