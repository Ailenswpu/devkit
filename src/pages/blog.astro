---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BLOG_POSTS } from '../data/blog';
import { SITE_NAME } from '../lib/seo';
---
<BaseLayout
  title={`Blog — ${SITE_NAME}`}
  description="Practical notes about private developer tools, JSON debugging, identifiers and browser-based workflows."
  path="/blog"
>
  <section class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <header class="max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">inbrowser.sh Blog</h1>
      <p class="mt-3 text-muted leading-7">
        Practical notes for developers using browser-based utilities: safer debugging habits,
        cleaner examples, and small workflow choices that matter over time.
      </p>
    </header>

    <div class="mt-8 grid gap-4">
      {BLOG_POSTS.map((post) => (
        <article class="card p-5 md:p-6">
          <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
            <span>{post.category}</span>
            <span aria-hidden="true">/</span>
            <time datetime={post.date}>{post.date}</time>
            <span aria-hidden="true">/</span>
            <span>{post.readingTime}</span>
          </div>
          <h2 class="mt-3 text-xl font-semibold tracking-tight">
            <a class="hover:text-accent" href={`/blog/${post.slug}`}>{post.title}</a>
          </h2>
          <p class="mt-2 text-sm text-muted leading-6">{post.description}</p>
          <a class="mt-4 inline-flex text-sm font-semibold text-accent hover:underline" href={`/blog/${post.slug}`}>
            Read article
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
